<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.board.springboard.model.mapper.BoardImageMapper">

    <!-- 전체 게시물 조회 -->
    <select id="이미지목록" resultType="com.board.springboard.model.dto.BoardImage">
        SELECT *
        FROM board_images
        ORDER BY board_no DESC
    </select>

    <!-- 게시물 하나 조회
    WHERE board_no = #{???}
    DBEAVER의 SQL 에서 하나의 게시물을 조회할 경우  WHERE board_no = 1 과 같이 작성
    JAVA 에서 클라이언트가 보고자하는 상세 게시물을 클라이언트 눈에보여줄 필요가 있다.

    WHERE board_no = #{???} 는 소비자가 선택한 번호를 넣는 곳
    #{???} = JSP 에서 소비자가 선택한 번호를 백엔드로 넘겨받음
             소비자가 선택한 번호를 넘겨받은 백엔드는 SQL에 전달하기 위에 데이터를 담을 공간 필요
             데이터가 담길 공간을 com.board.springboard.model.dto.Board 내부에 작성한
             변수 공간을 선택하고, 선택된 공간을 #{???} 공간의 명칭을 작성하는 것


    -->
    <!-- 게시물 추가 -->
    <insert id="이미지저장" parameterType="com.board.springboard.model.dto.BoardImage">
        INSERT INTO board_images (board_no, img_path)
        VALUES (#{board_no}, #{img_path})
    </insert>




    <!-- 게시물 삭제 -->
    <delete id="이미지전체삭제" parameterType="int">
        DELETE FROM board_images
        WHERE board_no = #{board_no}
    </delete>




</mapper>